# ============================================
# Environment and secrets — NEVER commit these
# ============================================
.env
.env.*
*.env
.env.local
.env.*.local
secrets/
credentials/
*.pem
*.key
*.crt
*.p12

# ============================================
# Data directories (generated by the layers)
# ============================================

# Layer 1: Graphify output
graphify-out/

# Layer 2: Code Review Graph database
.code-review-graph/

# Layer 3: Neo4j (if running outside Docker)
neo4j_data/
neo4j_logs/
neo4j_plugins/
data/

# Layer 5: Qdrant local storage
.qdrant-data/
qdrant_storage/

# Layer 6: Claude Code memory (auto-generated)
.claude/

# Layer 7: Session logs
*.jsonl

# Context graph working files
*.sqlite
*.sqlite-journal
*.db

# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.venv/
venv/
env/
.eggs/
*.whl

# Embedding model cache (downloaded on first run)
.cache/

# ============================================
# Node.js
# ============================================
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# Go
# ============================================
*.exe
*.exe~
*.dll
*.so
*.dylib

# ============================================
# OS files
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ============================================
# IDE / Editor
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ============================================
# Docker (local volumes if mapped)
# ============================================
docker-data/

# ============================================
# Logs
# ============================================
*.log
logs/
